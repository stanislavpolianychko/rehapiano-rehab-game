# RehaPiano Streamer - Environment Configuration
#
# Copy this file to .env and adjust values as needed.
# The streamer reads these environment variables at startup.

# =============================================================================
# Recording Directories
# =============================================================================
# Recording output directory (raw IMU data from WebSocket)
# Structure: {RECORDINGS_DIR}/raw/*.jsonl.gz, {RECORDINGS_DIR}/metadata/*.meta.json
#
# For Docker (with data-sync integration):
#   RECORDINGS_DIR=/app/recordings
#   (mounted to watched_folder/rehapiano-streamer in docker-compose)
#
# For native/local development:
#   RECORDINGS_DIR=./watched_folder/rehapiano-streamer
#
RECORDINGS_DIR=/app/recordings

# Game metadata base directory
# Each game saves to its own subfolder: {GAME_METADATA_DIR}/{game_name}/*.json
# e.g., apps/flappy-hand/, apps/balance-trainer/
#
# For Docker (with data-sync integration):
#   GAME_METADATA_DIR=/app/watched_folder/apps
#
# For native/local development:
#   GAME_METADATA_DIR=./watched_folder/apps
#
GAME_METADATA_DIR=/app/watched_folder/apps

# =============================================================================
# HTTP Server Settings
# =============================================================================
# HTTP_HOST=0.0.0.0
# HTTP_PORT=5555

# =============================================================================
# WebSocket Settings
# =============================================================================
# WS_HEARTBEAT_INTERVAL=2.0

# =============================================================================
# Recording Limits
# =============================================================================
# DEFAULT_RECORDING_DURATION_S=300
# HARD_CAP_RECORDING_S=900
