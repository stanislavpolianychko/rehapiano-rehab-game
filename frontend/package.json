{
  "name": "rehapiano-game-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Rehabilitation game using the RehaPiano device",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' '*.html'",
    "format:check": "prettier --check 'src/**/*.ts' '*.html'"
  },
  "dependencies": {
    "howler": "^2.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/howler": "^2.2.11",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.0.0"
  }
}
